{
    "vae_config_path": "configs/model_config.json",
    "training": {
        "seed": 42,
        "batch_size": 4,
        "num_epochs": 20,
        "gradient_clip_val": 1.0,
        "accumulate_grad_batches": 8,
        "precision": "bf16-mixed",
        "num_workers": 0,
        "use_ema": true,
        "ema_decay": 0.9999,
        "ema_update_interval": 1,
        "max_train_steps": -1,
        "override_lr_on_resume": false,
        "reset_scheduler_on_resume": false,
        "allow_tf32": true,
        "generator_optimizer": {
            "type": "AdamW",
            "learning_rate": 4.5e-6,
            "adam_beta1": 0.9,
            "adam_beta2": 0.999,
            "weight_decay": 0.01,
            "lr_scheduler": "cosine",
            "lr_warmup_steps": 500,
            "lr_num_cycles": 0.5,
            "lr_power": 1.0
        },
        "discriminator_optimizer": {
            "type": "AdamW",
            "learning_rate": 4.5e-6,
            "adam_beta1": 0.5,
            "adam_beta2": 0.9,
            "weight_decay": 0.0,
            "lr_scheduler": "cosine",
            "lr_warmup_steps": 0,
            "lr_num_cycles": 0.5,
            "lr_power": 1.0
        }
    },
    "compile": {
        "enabled": true
    },
    "distributed": {
        "accelerator": "gpu",
        "devices": 1,
        "strategy": "auto",
        "sync_batchnorm": false,
        "find_unused_parameters": false,
        "gradient_as_bucket_view": true
    },
    "discriminator": {
        "input_nc": 3,
        "ndf": 64,
        "n_layers": 3,
        "norm_type": "spectral_group",
        "num_groups": 32
    },
    "loss": {
        "rec_loss_type": "l2",
        "kl_weight": 1e-6,
        "perceptual_weight": 0.5,
        "disc_weight": 1.0,
        "disc_factor": 0.5,
        "disc_start_step": 50001,
        "disc_loss_type": "hinge",
        "use_adaptive_disc_weight": true,
        "adaptive_weight_max": 10.0
    },
    "data": {
        "dataset_name": "clane9/imagenet-100",
        "image_column": "image",
        "cache_dir": "./.cache/huggingface",
        "resolution": 256,
        "center_crop": true,
        "random_flip": true
    },
    "checkpoint": {
        "save_top_k": 3,
        "save_every_n_steps": 1000,
        "monitor": "val/rec_loss",
        "mode": "min"
    },
    "logging": {
        "project": "sd_vae_baseline",
        "name": "vae_training",
        "log_every_n_steps": 5,
        "val_check_interval": 500,
        "log_images_every_n_steps": 100,
        "num_val_images": 4
    },
    "paths": {
        "output_dir": "./outputs",
        "log_dir": "./outputs/logs",
        "checkpoint_dir": "./outputs/checkpoints"
    }
}
