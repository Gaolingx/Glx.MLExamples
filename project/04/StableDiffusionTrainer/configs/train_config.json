{
  "output_dir": "outputs/sd15-lightning",
  "pretrained_model_name_or_path": null,
  "clip_model_name_or_path": "CompVis/stable-diffusion-v1-4",
  "vae_model_name_or_path": "CompVis/stable-diffusion-v1-4",
  "scheduler_config_path": "models/scheduler/scheduler_config.json",
  "unet_config_path": "models/unet/config.json",
  "dataset": {
    "name": "Mercity/laion-subset",
    "split": "train",
    "image_column": "image",
    "caption_column": "caption",
    "cache_dir": "./.cache/huggingface",
    "resolution": 512,
    "center_crop": true,
    "random_flip": true,
    "num_workers": 4
  },
  "training": {
    "seed": 42,
    "batch_size": 2,
    "max_epochs": 1,
    "max_steps": -1,
    "accumulate_grad_batches": 1,
    "precision": "16-mixed",
    "learning_rate": 4.5e-6,
    "weight_decay": 0.01,
    "adam_beta1": 0.9,
    "adam_beta2": 0.999,
    "adam_epsilon": 1e-08,
    "max_grad_norm": 1.0,
    "lr_scheduler": "cosine",
    "lr_warmup_steps": 100,
    "override_lr_on_resume": false,
    "reset_scheduler_on_resume": false,
    "num_train_timesteps": 1000,
    "prediction_type": "epsilon",
    "gradient_checkpointing": true,
    "enable_xformers_memory_efficient_attention": false,
    "allow_tf32": true
  },
  "distributed": {
    "accelerator": "auto",
    "devices": "auto",
    "strategy": "auto",
    "sync_batchnorm": false,
    "find_unused_parameters": false,
    "gradient_as_bucket_view": true
  },
  "lora": {
    "enabled": false,
    "adapter_name": "default",
    "rank": 16,
    "alpha": 16,
    "dropout": 0.0,
    "bias": "none",
    "target_modules": [
      "to_q",
      "to_k",
      "to_v",
      "to_out.0"
    ],
    "init_lora_weights": true,
    "init_path": null
  },
  "clip": {
    "skip": 1
  },
  "validation": {
    "enabled": true,
    "every_n_steps": 500,
    "seed": 42,
    "sampler": "dpmpp_2m",
    "scheduler": "karras",
    "num_inference_steps": 25,
    "guidance_scale": 7.5,
    "height": 512,
    "width": 512,
    "negative_prompt": "low quality, blurry",
    "prompts": [
      "portrait photo of a girl, photograph, highly detailed face, depth of field, moody light, golden hour",
      "Astronaut in a jungle, cold color palette, muted colors, detailed, 8k"
    ]
  },
  "checkpoint": {
    "dirpath": "outputs/sd15-lightning/checkpoints",
    "save_top_k": 3,
    "monitor": "train/loss",
    "mode": "min",
    "save_last": true,
    "every_n_train_steps": 500
  },
  "logging": {
    "tensorboard_save_dir": "outputs/sd15-lightning/tb_logs",
    "name": "sd15_lightning",
    "log_every_n_steps": 10
  },
  "inference": {
    "seed": 42,
    "sampler": "dpmpp_2m",
    "scheduler": "karras",
    "num_inference_steps": 100,
    "guidance_scale": 7.5,
    "height": 512,
    "width": 512,
    "denoise_strength": 0.75,
    "negative_prompt": "low quality, blurry",
    "output_dir": "outputs/sd15-lightning/inference"
  }
}
